generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Core User model representing clients, admins, and support staff.
model User {
  /// Unique identifier for the user (UUID).
  id                       String         @id @default(uuid())
  /// Full name of the user.
  name                     String
  /// Unique email address, used for login.
  email                    String         @unique
  /// Contact phone number.
  phone                    String?
  /// Hashed password.
  password                 String
  /// Role assigned to the user.
  role                     String         @default("CLIENT")
  /// Corresponding User ID in the Traccar backend.
  traccarUserId            Int?           @unique
  /// Whether the account is currently enabled.
  isActive                 Boolean        @default(true)
  /// Number of consecutive failed login attempts.
  failedLoginAttempts      Int            @default(0)
  /// Timestamp until which the account is locked due to login failures.
  lockUntil                DateTime?
  /// Whether the user has verified their email address.
  isEmailVerified          Boolean        @default(false)
  /// Secret token for email verification.
  emailVerificationToken   String?
  /// Expiry for the email verification token.
  emailVerificationExpires DateTime?
  /// Token for password reset requests.
  resetPasswordToken       String?
  /// Expiry for the password reset token.
  resetPasswordExpires     DateTime?
  /// Secret key for TOTP-based Two-Factor Authentication.
  totpSecret               String?
  /// Whether Two-Factor Authentication is enabled for this user.
  isTotpEnabled            Boolean        @default(false)
  /// Timestamp when the user was created.
  createdAt                DateTime       @default(now())
  /// Timestamp of the last update to this record.
  updatedAt                DateTime       @updatedAt
  /// Soft-delete timestamp; if set, the record is considered deleted.
  deletedAt                DateTime?
  loginHistory             LoginHistory[]
  payments                 Payment[]
  subscriptions            Subscription[]
  vehicles                 Vehicle[]

  @@index([email])
  @@index([traccarUserId])
  @@index([isActive])
}

/// Represents a tracking unit (vehicle or asset) managed by a user.
model Vehicle {
  /// Unique identifier (UUID).
  id                String    @id @default(uuid())
  /// Friendly name for the vehicle.
  name              String
  /// Unique IMEI number of the GPS tracking device.
  imei              String    @unique
  /// Type of vehicle (e.g., Car).
  type              String?
  /// Specific model name.
  model             String?
  /// License plate number.
  plate             String?
  /// ID of the user who owns this vehicle.
  userId            String
  /// Corresponding Device ID in the Traccar backend.
  traccarDeviceId   Int?      @unique
  /// ID of the 'Safe Parking' geofence in Traccar.
  traccarGeofenceId Int?      @unique
  /// Whether 'Safe Parking' mode is enabled.
  safeParkingOn     Boolean   @default(false)
  /// Latitude for safe parking.
  parkingLat        Float?
  /// Longitude for safe parking.
  parkingLng        Float?
  /// Radius for safe parking.
  parkingRadius     Float?
  /// Creation timestamp.
  createdAt         DateTime  @default(now())
  /// Update timestamp.
  updatedAt         DateTime  @updatedAt
  /// Soft-delete timestamp.
  deletedAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([imei])
}

/// Represents a service subscription for a user.
model Subscription {
  /// Unique identifier (UUID).
  id        String    @id @default(uuid())
  /// Owner of the subscription.
  userId    String
  /// Current status of the subscription.
  status    String    @default("ACTIVE")
  /// ID of the pricing plan.
  planId    String?
  /// Price paid for the current period (Decimal).
  price     Decimal
  /// When the current subscription period ends.
  expiresAt DateTime
  /// Creation timestamp.
  createdAt DateTime  @default(now())
  /// Update timestamp.
  updatedAt DateTime  @updatedAt
  /// Soft-delete timestamp.
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([planId])
}

/// Record of a payment transaction.
model Payment {
  /// Unique identifier (UUID).
  id            String    @id @default(uuid())
  /// User who made the payment.
  userId        String
  /// Amount paid (Decimal).
  amount        Decimal
  /// Payment status.
  status        String    @default("PENDING")
  /// External transaction ID (e.g., Razorpay/Stripe).
  transactionId String?
  /// Method of payment (e.g., RAZORPAY).
  paymentMethod String?
  /// Creation timestamp.
  createdAt     DateTime  @default(now())
  /// Soft-delete timestamp.
  deletedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([transactionId])
}

model LoginHistory {
  id        String    @id @default(uuid())
  userId    String
  ipAddress String?
  device    String?
  success   Boolean
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model SignedPosition {
  id        String   @id @default(uuid())
  deviceId  Int
  latitude  Float
  longitude Float
  timestamp DateTime
  signature String
  hash      String
  createdAt DateTime @default(now())

  @@index([deviceId])
  @@index([timestamp])
}

/// System-wide audit logs for sensitive actions.
model AuditLog {
  /// Unique identifier (UUID).
  id        String   @id @default(uuid())
  /// User performing the action (optional).
  userId    String?
  /// Name of the action (e.g., DELETE_VEHICLE).
  action    String
  /// Affected resource type.
  resource  String
  /// JSON payload with action details.
  payload   String?
  /// Requester's IP address.
  ipAddress String?
  /// Creation timestamp.
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
}
