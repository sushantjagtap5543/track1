version: '3.8'

# GeoSurePath Local Development Overrides
# Copy this to 'docker-compose.override.yml' to enable

services:
  saas-api:
    volumes:
      - ./saas:/app:rw
      - /app/node_modules # Don't overwrite node_modules with host
    command: npm run dev
    environment:
      - NODE_ENV=development

  # traccar:
  #   volumes:
  #     - ./traccar-web/src:/opt/traccar/web/src:ro # For frontend dev
