set $saas_upstream http://saas-api:3001;

# Gzip Compression
gzip on;
gzip_proxied any;
gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;
gzip_vary on;

# Static Asset Caching for Traccar Assets
location ~* ^/assets/.* {
    proxy_pass http://traccar:8082;
    expires 30d;
    add_header Cache-Control "public, no-transform";
    access_log off;
}

location ~ ^/api/(status|health|auth|vehicles|billing|admin|reports|webhooks|ai|v1|saas) {
    proxy_pass http://saas-api:3001;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 30s;
}

location /api-docs {
    proxy_pass http://saas-api:3001;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
