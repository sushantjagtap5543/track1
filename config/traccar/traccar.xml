<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>
<properties>

    <entry key='database.driver'>org.postgresql.Driver</entry>
    <entry key='database.url'>jdbc:postgresql://db:5432/geosurepath?currentSchema=public</entry>
    <entry key='database.user'>geosurepath</entry>
    <entry key='database.password'>change-this-to-something-long-and-random</entry>

    <entry key='database.maxPoolSize'>100</entry>
    <entry key='database.minPoolSize'>20</entry>
    <entry key='database.checkoutTimeout'>10000</entry>

    <!-- Enabled all supported device binary decoders -->

    <entry key='l100.port'>5064</entry>
    <entry key='its.port'>5180</entry>

    <entry key='web.path'>./modern</entry>
    <entry key='web.port'>8082</entry>

    <entry key='geofence.polyline'>true</entry>
    <entry key='server.statistics'>false</entry>
    
    <!-- Logging and Performance -->
    <entry key='logger.level'>info</entry>
    <entry key='logger.enable'>true</entry>
    <entry key='distance.enable'>true</entry>
    <entry key='processing.computedAttributes.enable'>true</entry>

    <!-- 10k Device Performance: Aggressive Filtering -->
    <entry key='filter.enable'>true</entry>
    <entry key='filter.limit'>60</entry> <!-- 60s limit for high frequency devices -->
    <entry key='filter.distance'>20</entry> <!-- 20m distance threshold -->
    <entry key='filter.invalid'>true</entry>
    <entry key='filter.duplicate'>true</entry>
    <entry key='filter.stationary'>true</entry>

    <!-- Security -->
    <entry key='registration.enable'>false</entry>
    <entry key='event.geofence.handler'>true</entry>

</properties>
